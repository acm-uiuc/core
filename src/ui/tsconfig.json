{
  "compilerOptions": {
    "types": [
      "node",
      "@testing-library/jest-dom",
      "vitest/globals"
    ],
    "target": "ESNext",
    "outDir": "../../dist_ui",
    "useDefineForClassFields": true,
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ESNext"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "paths": {
      "@ui/*": [
        "./*"
      ],
      "@common/*": [
        "../common/*"
      ]
    },
    "rootDir": "..",
  },
  "include": [
    "./**/*"
  ],
}
