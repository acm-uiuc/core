{
  "extends": "@tsconfig/node24/tsconfig.json",
  "compilerOptions": {
    "module": "Node16",
    "rootDir": "../",
    "outDir": "../../dist",
    "paths": {
      "*": ["../*"]
    }
  },
  "ts-node": {
    "esm": true
  },
  "include": ["../api/**/*.ts", "../common/**/*.ts"],
  "exclude": ["../../node_modules", "../../dist"]
}
